# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/

# IDE
.vscode/
.idea/
*.swp
.DS_Store

# MS Office lockfiles
~$*

# Project artifacts (regenerated on demand)
mlruns/
mlartifacts/
models/*.pkl
models/*.joblib
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/raw/processed.cleveland.data
# Commit the canonical train/test split so reviewers can score the
# served model against the exact rows used during evaluation.
!data/processed/train.csv
!data/processed/test.csv
# Allow committed EDA / evaluation figures referenced from REPORT.md.
# Only ignore PDFs (large) and keep .gitkeep marker.
reports/figures/*.pdf
!reports/figures/.gitkeep

# Docker / K8s
*.tar
kubeconfig
