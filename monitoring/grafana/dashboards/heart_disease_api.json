{
  "title": "Heart Disease API",
  "uid": "heart-disease-api",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": {"from": "now-15m", "to": "now"},
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Requests / sec",
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 0},
      "targets": [{
        "expr": "sum(rate(http_requests_total{job=\"heart-disease-api\"}[1m]))",
        "refId": "A"
      }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Error rate (5xx)",
      "gridPos": {"h": 6, "w": 6, "x": 6, "y": 0},
      "targets": [{
        "expr": "sum(rate(http_requests_total{job=\"heart-disease-api\",status=~\"5..\"}[5m]))",
        "refId": "A"
      }]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "P95 latency (s)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [{
        "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"heart-disease-api\"}[5m])) by (le))",
        "refId": "A"
      }]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Requests by endpoint",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [{
        "expr": "sum(rate(http_requests_total{job=\"heart-disease-api\"}[1m])) by (handler)",
        "refId": "A"
      }]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Status codes",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [{
        "expr": "sum(rate(http_requests_total{job=\"heart-disease-api\"}[1m])) by (status)",
        "refId": "A"
      }]
    }
  ]
}
